# Consolidated Environment Variables for Docker Deployment

# Database (Internal to Docker Network)
MYSQL_DATABASE=legal_case_db
MYSQL_USER=legal_user
MYSQL_PASSWORD=legal_password
MYSQL_ROOT_PASSWORD=root_password

# Authentication (Must be identical for Frontend and Backend)
APP_JWT_SECRET=super_secret_lexora_key_2026

# Production Base URLs (Assumed based on Nginx config)
DOMAIN_NAME=lexora.raghavarora.dev
CORS_ORIGIN=https://lexora.raghavarora.dev
NEXT_PUBLIC_API_BASE_URL=https://lexora.raghavarora.dev/api

# Server-Side Internal URL (Inside Docker Network)
BACKEND_INTERNAL_URL=http://backend:4000/api
